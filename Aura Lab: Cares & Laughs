function pickRandomFeatured() {
  const pool = sitesData.filter(s => s.title && s.desc && s.url);
  if (!pool.length) return null;
  const idx = Math.floor(Math.random() * pool.length);
  const s = pool[idx];
  return {
    id: s.id,
    title: s.title,
    desc: s.desc,
    url: s.url
  };
}

function loadDailyFeatured() {
  const today = new Date().toISOString().slice(0, 10); // "YYYY-MM-DD"
  const saved = JSON.parse(localStorage.getItem("dailyFeatured") || "null");

  let featured;

  if (saved && saved.date === today) {
    featured = saved.item;
  } else {
    featured = pickRandomFeatured();
    if (!featured) return;
    localStorage.setItem("dailyFeatured", JSON.stringify({
      date: today,
      item: featured
    }));
  }

  const titleEl = document.getElementById("featuredTitle");
  const descEl = document.getElementById("featuredDesc");
  const linkEl = document.getElementById("featuredLink");

  if (titleEl) titleEl.textContent = featured.title;
  if (descEl) descEl.textContent = featured.desc;
  if (linkEl)  linkEl.href = featured.url;
}


