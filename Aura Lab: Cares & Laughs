    .profile-avatar {
      width: 56px;
      height: 56px;
      border-radius: 18px;
      border: 3px solid #38bdf8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      background: radial-gradient(circle at top, #1d4ed8, #020617);
      overflow: hidden;
      color: #e5e7eb;
    }

    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-text {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .profile-name {
      font-weight: 650;
      font-size: 0.98rem;
    }

    .profile-subtitle {
      font-size: 0.75rem;
      color: var(--text-muted-dark);
    }

    /* Buttons / Inputs */
    .btn {
      appearance: none;
      border: none;
      border-radius: 999px;
      padding: 0.4rem 0.95rem;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      transition: transform 0.15s, box-shadow 0.15s, background 0.15s, color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .btn-primary {
      background: var(--accent-color);
      color: #ffffff;
      box-shadow: 0 8px 18px rgba(244, 63, 94, 0.35);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 24px rgba(244, 63, 94, 0.45);
      background: #e0004d;
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-main-dark);
      border: 1px solid rgba(148, 163, 184, 0.5);
    }

    .btn-ghost:hover {
      background: rgba(148, 163, 184, 0.12);
    }

    .input {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.55);
      padding: 0.45rem 0.9rem;
      font-size: 0.85rem;
      background: rgba(15, 23, 42, 0.95);
      color: var(--text-main-dark);
      min-width: 0;
      transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    }

    .input:focus {
      outline: none;
      border-color: var(--accent-color-soft);
      box-shadow: 0 0 0 1px rgba(244, 63, 94, 0.4);
    }

    /* Hero row (featured + progress) */
    .hero-row {
      display: grid;
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    @media (max-width: 900px) {
      .hero-row {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    #featuredBox {
      padding: 1.1rem 1.2rem;
