      background: radial-gradient(circle at 0% 0%, rgba(248, 250, 252, 0.12), rgba(15, 23, 42, 0.98));
      box-shadow: var(--shadow-soft);
      border: 1px solid rgba(148, 163, 184, 0.45);
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    #featuredBox::after {
      content: "";
      position: absolute;
      inset: -60%;
      background: radial-gradient(circle at 10% 0%, rgba(244, 63, 94, 0.16), transparent 60%);
      pointer-events: none;
    }

    #featuredTitle {
      font-weight: 600;
      font-size: 0.98rem;
      position: relative;
      z-index: 1;
    }

    #featuredDesc {
