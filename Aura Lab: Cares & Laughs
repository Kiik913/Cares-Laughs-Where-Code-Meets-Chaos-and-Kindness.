 const userNameElem   = document.getElementById("userName");
const userAvatarElem = document.getElementById("userAvatar");
const editProfileBtn = document.getElementById("editProfileBtn");

function renderProfile() {
  userNameElem.textContent = userProfile.name || "Guest";

  if (userProfile.emojiAvatar) {
    userAvatarElem.innerHTML = userProfile.emojiAvatar;
    userAvatarElem.style.display = "flex";
    userAvatarElem.style.alignItems = "center";
    userAvatarElem.style.justifyContent = "center";
    userAvatarElem.style.fontSize = "2.6rem";
  } else {
    const seed = encodeURIComponent(userProfile.name || "Guest");
    const url =
      userProfile.avatar ||
      `https://api.dicebear.com/8.x/thumbs/svg?seed=${seed}`;
    userAvatarElem.innerHTML = `<img src="${url}" alt="Avatar">`;
  }
}
editProfileBtn.onclick = () => {
  const newName = prompt("Enter your display name:", userProfile.name);
  if (!newName || !newName.trim()) return;
  userProfile.name = newName.trim();

  const choice = prompt(
    "Pick avatar style:\n\n" +
    "1) Paste image URL (photo / PFP)\n" +
    "2) Emoji avatar (😎, 🐉, 🎮 etc.)\n" +
    "3) Random cute avatar (DiceBear)"
  );

  if (choice === "1") {
    const url = prompt(
      "Paste image URL for your avatar (PNG or JPG, 320×320 works best):"
    );
    if (!url || !url.trim()) {
      alert("No URL entered. Keeping your old avatar.");
    } else {
      const clean = url.trim();
      const lower = clean.toLowerCase();

      if (
        !lower.endsWith(".png") &&
        !lower.endsWith(".jpg") &&
        !lower.endsWith(".jpeg")
      ) {
        alert("Avatar URL must end with .png, .jpg, or .jpeg and be around 320×320 size.");
