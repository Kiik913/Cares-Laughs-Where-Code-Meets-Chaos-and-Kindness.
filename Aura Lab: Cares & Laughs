      root.style.setProperty('--accent-1', e.target.value);
    });
    document.getElementById('accent2').addEventListener('input', e => {
      root.style.setProperty('--accent-2', e.target.value);
    });
    document.getElementById('cardBg').addEventListener('input', e => {
      const val = e.target.value;
      // convert solid color to slightly transparent background
      root.style.setProperty('--card-bg', hexToRgba(val, 0.85));
    });

    function hexToRgba(hex, alpha) {
      const h = hex.replace('#', '');
      const r = parseInt(h.substring(0, 2), 16);
      const g = parseInt(h.substring(2, 4), 16);
      const b = parseInt(h.substring(4, 6), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }
  </script>
