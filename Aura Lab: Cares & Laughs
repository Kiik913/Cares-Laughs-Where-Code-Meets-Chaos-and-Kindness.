      z-index: 1;
    }

    #featuredLink {
      position: relative;
      z-index: 1;
      text-decoration: none;
    }

    .progress-card {
      padding: 0.9rem 1rem;
      border-radius: var(--radius-card);
      background: rgba(15, 23, 42, 0.95);
      box-shadow: var(--shadow-subtle);
      border: 1px solid rgba(148, 163, 184, 0.4);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      font-size: 0.82rem;
    }

    .progress-label {
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color-soft);
    }

    .progress-row {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .progress-pill {
      font-size: 0.78rem;
      color: var(--text-muted-dark);
    }

    .progress-bar-outer {
      width: 100%;
      height: 6px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.25);
      overflow: hidden;
    }

    .progress-bar-inner {
      height: 100%;
      width: 0%;
      border-radius: 999px;
      background: linear-gradient(90deg, #f97316, #f50057);
      transition: width 0.3s ease-out;
    }

    /* Controls row */
    .controls-wrapper {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.9rem;
    }

    .controls-left,
    .controls-right {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }

    #searchInput {
      min-width: 180px;
    }

    /* Layout switch */
    #layoutSwitch button {
      margin: 0;
      padding: 0.35rem 0.85rem;
      font-size: 0.78rem;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.6);
      background: transparent;
      color: var(--text-main-dark);
      cursor: pointer;
    }

    #layoutSwitch button.active {
      background: rgba(248, 250, 252, 0.12);
      border-color: var(--accent-color-soft);
      color: #f9fafb;
    }

    /* Cards container */
    .container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.3rem;
      margin-top: 0.8rem;
    }

    .container.list {
      display: block;
    }

    .container.list .card {
      max-width: 640px;
      margin: 0.7rem auto;
      flex-direction: row;
      align-items: stretch;
