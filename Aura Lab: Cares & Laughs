.card {
  background: var(--card-bg);
  border-radius: 18px;
  box-shadow: 0 16px 40px rgba(15, 23, 42, 0.8);
  padding: 1.05rem 1.1rem;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(51, 65, 85, 0.9);
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  cursor: pointer;
  transition:
    transform 0.18s ease-out,
    box-shadow 0.18s ease-out,
    border-color 0.18s ease-out,
    background 0.18s ease-out;
}

.card:hover {
  transform: translateY(-3px) scale(1.012);
  box-shadow: 0 22px 50px rgba(15, 23, 42, 0.92);
  border-color: var(--accent-color-soft);
  background:
    radial-gradient(circle at 0% 0%, rgba(244, 63, 94, 0.18), transparent 55%),
    var(--card-bg);
}

/* Header row */
.card-header-row {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}

/* Image */
.card img,
.card-image {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  object-fit: cover;
  flex-shrink: 0;
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.8);
  background: #020617;
}

/* Text */
.card-text {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 0.98rem;
  font-weight: 670;
  margin: 0 0 0.18rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Description – full, comfy to read */
.card-desc {
  font-size: 0.87rem;
  line-height: 1.6;
  color: var(--text-muted-dark);
  margin-top: 0.2rem;
  letter-spacing: 0.003em;
  display: block;
  overflow: visible;
  text-overflow: clip;
}

/* Chips */
.card-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.35rem;
  font-size: 0.72rem;
}

.card-chip {
  padding: 0.18rem 0.6rem;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.96);
  border: 1px solid rgba(148, 163, 184, 0.55);
  color: var(--text-muted-dark);
  backdrop-filter: blur(6px);
}


    .favorite-star {
