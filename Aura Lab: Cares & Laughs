  // show popup after delay
  setTimeout(showRatingPopup, RATING_DELAY);

  const stars = document.querySelectorAll("#ratingStars span");
  const msg = document.getElementById("ratingMessage");

  stars.forEach(star => {
    star.addEventListener("click", () => {
      const value = parseInt(star.dataset.value, 10);

      // highlight selected stars
      stars.forEach(s => {
        const v = parseInt(s.dataset.value, 10);
        s.classList.toggle("active", v <= value);
      });

      if (value < 5) {
        msg.innerHTML =
          `Thanks for the feedback! If something felt off, ` +
          `message me on Instagram <a href="${INSTAGRAM_URL}" target="_blank" rel="noopener noreferrer">${INSTAGRAM_ID}</a>.<br>` +
          `Your problem will get a solution in a few days.`;
      } else {
        msg.textContent = "Thank you for the 5⭐! You’re awesome.";
      }
    });
  });
});
